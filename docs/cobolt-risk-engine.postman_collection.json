              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/risk/assess",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "risk",
                "assess"
              ]
            },
            "description": "Assess a transaction for AML risk. Rules run in parallel. Any triggered rule blocks the transaction.\n\nFields:\n- `userRef` — internal user identifier\n- `walletId` — source wallet address\n- `amount` — integer, smallest currency unit (e.g. cents)\n- `currency` — ISO 4217 3-letter code\n- `transactionType` — DEPOSIT | BUY_CRYPTO | WITHDRAW_CRYPTO\n- `chain` — required for BUY_CRYPTO and WITHDRAW_CRYPTO\n- `toWalletId` — required for BUY_CRYPTO and WITHDRAW_CRYPTO\n- `counterpartyRef` — optional on all types"
          },
