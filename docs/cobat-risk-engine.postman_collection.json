            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userRef\": \"usr_demo_001\",\n  \"walletId\": \"0x742d35Cc6634C0532925a3b844Bc9e7595f2bD18\",\n  \"amount\": 500000,\n  \"currency\": \"EUR\",\n  \"transactionType\": \"DEPOSIT\",\n  \"callbackUrl\": \"https://your-platform.com/webhooks/risk\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/risk/assess",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "risk", "assess"]
            },
            "description": "Submit a transaction for AML risk assessment. Rules run in parallel.\n\n**Required fields:**\n- `userRef` — internal user identifier\n- `walletId` — source wallet address or bank account\n- `amount` — integer, smallest currency unit (e.g. cents for EUR)\n- `currency` — ISO 4217 3-letter code\n- `transactionType` — `DEPOSIT` | `BUY_CRYPTO` | `WITHDRAW_CRYPTO`\n- `callbackUrl` — URL to POST the final decision to when AMLBot resolves asynchronously\n\n**Required for `BUY_CRYPTO` and `WITHDRAW_CRYPTO`:**\n- `chain` — blockchain network (e.g. `ETH`, `BTC`)\n- `destinationWalletId` — destination wallet address\n\n**Optional:**\n- `counterpartyId` — counterparty bank, exchange, or wallet identifier"
          },
