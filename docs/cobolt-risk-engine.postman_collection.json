{
  "info": {
    "name": "Cobat Risk Engine",
    "description": "Real-time AML transaction risk assessment API.\n\nBase URL: `{{base_url}}/api`\n\nAuth: All `/v1/` routes require `Authorization: Bearer {{api_key}}` header.\n\nTransaction types:\n- `DEPOSIT` — fiat deposit, no chain or toWalletId needed\n- `BUY_CRYPTO` — requires chain + toWalletId\n- `WITHDRAW_CRYPTO` — requires chain + toWalletId\n\n`counterpartyRef` is optional on all types.\n\nDecision logic: any rule triggers → `allow: false`. All rules pass → `allow: true`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "sk-test-api-key-change-in-production",
      "type": "string"
    }
  ],
  "item": [
