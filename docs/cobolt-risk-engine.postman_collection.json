            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userRef\": \"usr_demo_001\",\n  \"walletId\": \"0x742d35Cc6634C0532925a3b844Bc9e7595f2bD18\",\n  \"amount\": 500000,\n  \"currency\": \"EUR\",\n  \"transactionType\": \"DEPOSIT\"\n}",
              "options": {
                "raw": {
                  "language": "json"
