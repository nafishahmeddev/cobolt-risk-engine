  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx --watch --env-file=.env.local src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "tsx --env-file=.env.local dist/server.js",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "commitlint": "commitlint --edit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "husky": "^9.1.7",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "@hono/zod-validator": "^0.7.6",
    "@slack/web-api": "^7.15.2",
    "@types/node": "^25.6.0",
    "axios": "^1.16.0",
    "form-data": "^4.0.5",
    "hono": "^4.12.17",
    "mongoose": "^9.6.1",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "private": true
